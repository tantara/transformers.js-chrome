{
  "name": "tinywhale",
  "private": true,
  "engines": {
    "node": "^22.21.0",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "pnpm -F @acme/auth generate",
    "db:generate": "pnpm -F @acme/db generate",
    "db:migrate": "pnpm -F @acme/db migrate",
    "db:push": "pnpm -F @acme/db push",
    "db:studio": "pnpm -F @acme/db studio",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @acme/nextjs...",
    "dev:chrome": "turbo watch dev:chrome -F @acme/plasmo...",
    "dev:plasmo": "turbo watch dev:chrome dev:firefox -F @acme/plasmo...",
    "dev:firefox": "pnpm -F @acme/plasmo dev:firefox",
    "build:chrome": "turbo run build -F @acme/plasmo...",
    "build:firefox": "pnpm -F @acme/plasmo build:firefox",
    "build:safari": "pnpm -F @acme/plasmo build:safari",
    "package:chrome": "pnpm -F @acme/plasmo package",
    "package:firefox": "pnpm -F @acme/plasmo package:firefox",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest -p @acme/plasmo",
    "postinstall": "pnpm lint:ws",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@acme/prettier-config": "workspace:*",
    "@turbo/gen": "^2.5.8",
    "dotenv-cli": "^10.0.0",
    "path-browserify": "^1.0.1",
    "prettier": "catalog:",
    "stream-browserify": "^3.0.0",
    "turbo": "^2.5.8",
    "typescript": "catalog:",
    "url": "^0.11.0"
  },
  "prettier": "@acme/prettier-config",
  "@parcel/resolver-default": {
    "packageExports": true
  }
}
