{
  "name": "transformersjs-chrome",
  "displayName": "Private AI Assistant: Running LLM locally",
  "version": "0.0.5",
  "description": "Private AI Assistant enables users to interact with language models directly in their browser without an internet connection.",
  "author": "Taekmin Kim <tantara.tm@gmail.com>",
  "scripts": {
    "dev": "pnpm with-env plasmo dev",
    "build": "pnpm with-env plasmo build",
    "package": "pnpm with-env plasmo package",
    "with-env": "dotenv -e .env --",
    "postinstall": "bash postinstall/run.sh",
    "test:background": "node test/background.mjs",
    "test:inference": "node test/inference.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@plasmohq/storage": "^1.15.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "better-react-mathjax": "3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.2",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "plasmo": "0.90.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/chrome": "0.1.37",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.27",
    "dotenv-cli": "^11.0.0",
    "path-browserify": "^1.0.0",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "5.9.3",
    "url": "0.11.0"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "contextMenus",
      "scripting",
      "sidePanel",
      "storage",
      "unlimitedStorage"
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "~output/chtml/fonts/woff-v2/*"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'"
    }
  },
  "alias": {
    "sharp": "./postinstall/sharp-stub.js",
    "fs": "./postinstall/fs-stub.js",
    "node:fs": "./postinstall/fs-stub.js",
    "onnxruntime-node": "./postinstall/onnxruntime-node-stub.js"
  },
  "@parcel/resolver-default": {
    "packageExports": true
  }}
